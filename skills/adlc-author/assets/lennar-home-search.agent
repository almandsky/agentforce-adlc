# Lennar Home Search Agent
# ========================
#
# A complex real-world agent for Lennar home buyers featuring:
# - Multiple specialized topics for different buyer journey stages
# - Actions with Flow targets for inventory search and scheduling
# - Linked variables with visibility: "External" for service agents
# - after_reasoning patterns for follow-up actions
# - Proper two-level action system (Level 1 definitions + Level 2 invocations)
# - available when guards for conditional action visibility

system:
   instructions: |
      You are a Lennar Home Search Assistant helping prospective buyers find their perfect new home.
      Be warm, knowledgeable about Lennar communities, and proactive in understanding buyer preferences.
      Always ask about location preference, budget range, and home type before searching.
      When presenting results, highlight key features like Everything's Included amenities, energy efficiency, and community perks.
   messages:
      welcome: "Welcome to Lennar! I'm here to help you find your perfect new home. Let's start by learning about what you're looking for."
      error: "I apologize for the inconvenience. Let me try a different approach to help you."

config:
   developer_name: "LennarHomeSearchAgent"
   agent_label: "Lennar Home Search Assistant"
   description: "Helps prospective buyers find and tour Lennar homes matching their preferences"
   default_agent_user: "agent@lennar.com"  # REQUIRED: Change to valid Einstein Agent User
   agent_type: "AgentforceServiceAgent"

variables:
   # Service agent linked vars (required)
   EndUserId: linked string
      source: @MessagingSession.MessagingEndUserId
      description: "Messaging End User ID"
      visibility: "External"
   RoutableId: linked string
      source: @MessagingSession.Id
      description: "Messaging Session ID"
      visibility: "External"
   ContactId: linked string
      source: @MessagingEndUser.ContactId
      description: "Contact ID"
      visibility: "External"

   # Buyer preferences
   preferred_state: mutable string
      description: "Buyer's preferred state"
      default: ""
   preferred_city: mutable string
      description: "Buyer's preferred city"
      default: ""
   min_price: mutable number
      description: "Minimum budget"
      default: 0
   max_price: mutable number
      description: "Maximum budget"
      default: 0
   bedrooms_needed: mutable number
      description: "Number of bedrooms needed"
      default: 3
   home_type: mutable string
      description: "Single-family, townhome, or condo"
      default: ""

   # Search results
   search_results_count: mutable number
      description: "Number of homes found"
      default: 0
   selected_community: mutable string
      description: "Community selected for tour"
      default: ""
   tour_scheduled: mutable boolean
      description: "Whether a tour has been scheduled"
      default: False
   confirmation_number: mutable string
      description: "Tour confirmation number"
      default: ""

language:
   default_locale: "en_US"
   additional_locales: ""
   all_additional_locales: False

# ============================================================
# ENTRY POINT: Qualification
# ============================================================

start_agent: qualification

topic qualification:
   label: "Buyer Qualification"
   description: "Gather buyer preferences and qualify their needs"

   actions:
      # Level 1: Action DEFINITION with target and I/O schema
      capture_buyer_preferences:
         description: "Capture buyer's location and budget preferences"
         target: "flow://Capture_Buyer_Preferences"
         inputs:
            state:
               type: string
               description: "State the buyer wants to live in"
            city:
               type: string
               description: "City the buyer prefers"
            min_budget:
               type: number
               description: "Minimum budget"
            max_budget:
               type: number
               description: "Maximum budget"
            bedrooms:
               type: number
               description: "Number of bedrooms needed"
            home_type_pref:
               type: string
               description: "Home type preference"
         outputs:
            state:
               type: string
               description: "Confirmed state"
            city:
               type: string
               description: "Confirmed city"
            min_budget:
               type: number
               description: "Confirmed min budget"
            max_budget:
               type: number
               description: "Confirmed max budget"
            bedrooms:
               type: number
               description: "Confirmed bedrooms"
            home_type_result:
               type: string
               description: "Confirmed home type"

   reasoning:
      instructions: ->
         # Check if we already have preferences
         if @variables.preferred_state != "" and @variables.max_price > 0:
            | Great! I have your preferences. Let me search for homes.
            transition to @topic.home_search

         # Gather preferences
         | To help you find the perfect Lennar home, I'll need to know:
         | 1. What state and city are you looking in?
         | 2. What's your budget range?
         | 3. How many bedrooms do you need?
         | 4. Do you prefer single-family homes, townhomes, or condos?

      actions:
         # Level 2: Action INVOCATION with with/set bindings
         capture_prefs: @actions.capture_buyer_preferences
            description: "Capture buyer's location and budget preferences"
            with state = ...
            with city = ...
            with min_budget = ...
            with max_budget = ...
            with bedrooms = ...
            with home_type_pref = ...
            set @variables.preferred_state = @outputs.state
            set @variables.preferred_city = @outputs.city
            set @variables.min_price = @outputs.min_budget
            set @variables.max_price = @outputs.max_budget
            set @variables.bedrooms_needed = @outputs.bedrooms
            set @variables.home_type = @outputs.home_type_result

         proceed_to_search: @utils.transition to @topic.home_search
            description: "Move to home search"
            available when @variables.preferred_state != ""

# ============================================================
# HOME SEARCH: Find matching properties
# ============================================================

topic home_search:
   label: "Home Search"
   description: "Search Lennar inventory for homes matching buyer criteria"

   actions:
      # Level 1: Action DEFINITION (target + I/O schema)
      search_inventory:
         description: "Search available Lennar homes"
         target: "flow://Search_Lennar_Inventory"
         inputs:
            state:
               type: string
               description: "State to search in"
               is_required: True
            city:
               type: string
               description: "City to search in"
            min_price:
               type: number
               description: "Minimum price"
            max_price:
               type: number
               description: "Maximum price"
            bedrooms:
               type: number
               description: "Number of bedrooms"
            home_type_filter:
               type: string
               description: "Type of home"
         outputs:
            homes_found:
               type: number
               description: "Number of homes found"
               is_displayable: True
            communities:
               type: string
               description: "Matching communities"
               is_displayable: True
            price_ranges:
               type: string
               description: "Price ranges in results"
               is_displayable: True

   reasoning:
      instructions: ->
         # Post-action: Check search results
         if @variables.search_results_count > 0:
            | Excellent! I found {!@variables.search_results_count} homes matching your criteria.
            | Would you like to schedule a tour at any of these communities?

         # Initial search prompt
         | Searching for {!@variables.home_type} homes in {!@variables.preferred_city}, {!@variables.preferred_state}
         | Budget: ${!@variables.min_price} - ${!@variables.max_price}
         | Bedrooms: {!@variables.bedrooms_needed}

      actions:
         # Level 2: Action INVOCATION
         run_search: @actions.search_inventory
            description: "Search Lennar inventory"
            with state = @variables.preferred_state
            with city = @variables.preferred_city
            with min_price = @variables.min_price
            with max_price = @variables.max_price
            with bedrooms = @variables.bedrooms_needed
            with home_type_filter = @variables.home_type
            set @variables.search_results_count = @outputs.homes_found

         schedule_tour: @utils.transition to @topic.tour_scheduling
            description: "Schedule a community tour"
            available when @variables.search_results_count > 0

         adjust_criteria: @utils.transition to @topic.qualification
            description: "Adjust search criteria"

         get_community_info: @utils.transition to @topic.community_information
            description: "Learn about specific communities"

   after_reasoning:
      # Follow up if results found
      if @variables.search_results_count > 0:
         | Remember, all Lennar homes include Everything's Included features at no extra cost!

# ============================================================
# TOUR SCHEDULING: Book community visits
# ============================================================

topic tour_scheduling:
   label: "Tour Scheduling"
   description: "Schedule tours at Lennar community welcome centers"

   actions:
      # Level 1: Action DEFINITION
      book_community_tour:
         description: "Schedule a tour at a Lennar community"
         target: "flow://Schedule_Community_Tour"
         inputs:
            community_name:
               type: string
               description: "Name of the community"
               is_required: True
            preferred_date:
               type: date
               description: "Preferred tour date"
               is_required: True
            preferred_time:
               type: string
               description: "Preferred tour time"
            contact_phone:
               type: string
               description: "Contact phone number"
               is_required: True
            contact_email:
               type: string
               description: "Contact email"
         outputs:
            confirmation_number:
               type: string
               description: "Tour confirmation number"
               is_displayable: True
               is_used_by_planner: True
            scheduled_datetime:
               type: datetime
               description: "Scheduled tour date and time"
               is_displayable: True

   reasoning:
      instructions: ->
         # Check if already scheduled
         if @variables.tour_scheduled == True:
            | Your tour at {!@variables.selected_community} is confirmed!
            | Confirmation: {!@variables.confirmation_number}
            transition to @topic.follow_up

         | Let's schedule your tour! Which community would you like to visit?
         | What date and time work best for you?

      actions:
         # Level 2: Action INVOCATION (with slot-filling via ...)
         book_tour: @actions.book_community_tour
            description: "Book a community tour"
            with community_name = ...
            with preferred_date = ...
            with preferred_time = ...
            with contact_phone = ...
            with contact_email = ...
            set @variables.tour_scheduled = True
            set @variables.confirmation_number = @outputs.confirmation_number

         back_to_search: @utils.transition to @topic.home_search
            description: "Search for different homes"

# ============================================================
# COMMUNITY INFO: Detailed community information
# ============================================================

topic community_information:
   label: "Community Information"
   description: "Provide detailed information about Lennar communities"

   actions:
      # Level 1: Action DEFINITION
      get_community_details:
         description: "Get detailed community information"
         target: "flow://Get_Community_Details"
         inputs:
            community_name:
               type: string
               description: "Name of the community"
               is_required: True
         outputs:
            amenities:
               type: string
               description: "Community amenities"
               is_displayable: True
            schools:
               type: string
               description: "Nearby schools"
               is_displayable: True
            hoa_fees:
               type: string
               description: "HOA fees"
               is_displayable: True
            available_models:
               type: number
               description: "Number of available models"
               is_displayable: True

   reasoning:
      instructions: |
         I can provide detailed information about any Lennar community.
         Which community would you like to learn more about?
         I can share details about amenities, schools, HOA fees, and available home models.

      actions:
         # Level 2: Action INVOCATION
         get_details: @actions.get_community_details
            description: "Get community information"
            with community_name = ...

         schedule_visit: @utils.transition to @topic.tour_scheduling
            description: "Schedule a tour at this community"

         back_to_search: @utils.transition to @topic.home_search
            description: "Return to home search"

# ============================================================
# FOLLOW-UP: Post-tour and next steps
# ============================================================

topic follow_up:
   label: "Follow Up"
   description: "Handle post-tour follow-up and next steps"

   reasoning:
      instructions: |
         Great! Your tour is scheduled. Here are your next steps:
         1. Visit the Welcome Center at your scheduled time
         2. Bring a valid ID and be prepared to discuss financing
         3. Our New Home Consultant will show you available models
         4. Ask about current incentives and Everything's Included features

         Is there anything else I can help you with today?

      actions:
         additional_tours: @utils.transition to @topic.tour_scheduling
            description: "Schedule another tour"

         new_search: @utils.transition to @topic.qualification
            description: "Start a new search"
